page {
  background: #f8faf7;
  color: #233029;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin: 0;
  padding: 0 28rpx;
  border: 0;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 0;
  overflow: hidden;
}

button::after {
  border: 0;
}

button[disabled] {
  color: rgba(255, 255, 255, 0.74);
  background: #87a99a;
  opacity: 1;
}

.button-pressed {
  opacity: 0.84;
  transform: scale(0.99);
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
}

.section {
  margin-top: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 0;
}

.subtitle {
  margin-top: 12rpx;
  color: #687269;
  line-height: 1.55;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e7ebe4;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(55, 71, 62, 0.06);
}

.primary-btn {
  background: #2f6b55;
  color: #ffffff;
  font-weight: 700;
}

.ghost-btn {
  background: #ffffff;
  color: #2f6b55;
  border: 1rpx solid #d8e4dc;
}

.ghost-btn[disabled] {
  color: #9aa69f;
  background: #f3f6f2;
  border-color: #e3e8e2;
}

.muted {
  color: #758076;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #edf5ef;
  color: #2f6b55;
  font-size: 24rpx;
}
