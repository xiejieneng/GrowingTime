<view class="page albums-page">
  <view class="title">成长相册</view>
  <view class="subtitle">照片会按拍摄月份自动整理；带 GPS 信息的照片会显示拍摄坐标，后续可接入地图逆地理编码显示城市与地点名。</view>

  <view wx:if="{{groups.length}}" class="section">
    <view wx:for="{{groups}}" wx:key="month" class="month-group">
      <view class="month-head">
        <view>
          <view class="month-title">{{item.month}}</view>
          <view class="month-count">{{item.photos.length}} 张照片</view>
        </view>
      </view>

      <view class="photo-grid">
        <view wx:for="{{item.photos}}" wx:key="id" wx:for-item="photo" class="album-card panel" bindtap="previewPhoto" data-src="{{photo.compressedPath || photo.path}}">
          <image src="{{photo.compressedPath || photo.path}}" mode="aspectFill" fade-in="{{false}}" show-menu-by-longpress="{{true}}"></image>
          <button
            class="photo-delete"
            hover-class="photo-delete-pressed"
            loading="{{deletingPhotoId === photo.id}}"
            disabled="{{deletingPhotoId !== ''}}"
            data-id="{{photo.id}}"
            catchtap="deletePhoto"
          >删除</button>
          <view class="album-meta">
            <view class="album-date">{{photo.displayDate}}</view>
            <view class="album-place">{{photo.placeText}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty panel">
    <view class="empty-title">相册还是空的</view>
    <view class="empty-text">去“整理”页选择原图，系统会自动按拍摄时间生成成长月份。</view>
    <button class="primary-btn empty-btn" hover-class="button-pressed" bindtap="goUpload">开始整理</button>
  </view>
</view>
