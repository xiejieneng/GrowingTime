.albums-page {
  padding-bottom: 300rpx;
}

.page-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.manage-link {
  color: #2f6b55;
  font-size: 27rpx;
  font-weight: 700;
}

.month-group {
  margin-bottom: 36rpx;
}

.month-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.month-title {
  font-size: 34rpx;
  font-weight: 700;
}

.month-count {
  margin-top: 6rpx;
  color: #758076;
  font-size: 24rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.album-card {
  position: relative;
  border: 3rpx solid transparent;
  overflow: hidden;
}

.album-card.selected {
  border-color: #2f6b55;
}

.album-card image {
  display: block;
  width: 100%;
  height: 240rpx;
  background: #edf1ec;
}

.select-indicator {
  position: absolute;
  z-index: 2;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: rgba(35, 48, 41, 0.45);
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 800;
}

.select-indicator.checked {
  background: #2f6b55;
}

.batch-bar {
  position: fixed;
  z-index: 20;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(92rpx + env(safe-area-inset-bottom));
  height: 104rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8e1;
  border-radius: 12rpx;
  box-shadow: 0 12rpx 36rpx rgba(35, 48, 41, 0.16);
}

.batch-select {
  color: #2f6b55;
  font-weight: 700;
}

.batch-count {
  flex: 1;
  margin-left: 24rpx;
  color: #758076;
  font-size: 24rpx;
}

.batch-delete {
  width: 144rpx;
  min-height: 64rpx;
  height: 64rpx;
  padding: 0;
  color: #ffffff;
  background: #b34136;
  font-size: 25rpx;
}

.batch-delete[disabled] {
  color: #baaaa7;
  background: #f0e9e7;
}

.album-meta {
  padding: 16rpx;
}

.album-date {
  font-weight: 700;
}

.album-place {
  margin-top: 6rpx;
  color: #758076;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty {
  margin-top: 28rpx;
  padding: 44rpx 32rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  color: #758076;
  line-height: 1.55;
}

.empty-btn {
  width: 100%;
  margin-top: 30rpx;
}
