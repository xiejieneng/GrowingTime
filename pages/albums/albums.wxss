.albums-page {
  padding-bottom: 80rpx;
}

.month-group {
  margin-bottom: 36rpx;
}

.month-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.month-title {
  font-size: 34rpx;
  font-weight: 700;
}

.month-count {
  margin-top: 6rpx;
  color: #758076;
  font-size: 24rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.album-card {
  overflow: hidden;
}

.album-card image {
  display: block;
  width: 100%;
  height: 240rpx;
  background: #edf1ec;
}

.album-meta {
  padding: 16rpx;
}

.album-date {
  font-weight: 700;
}

.album-place {
  margin-top: 6rpx;
  color: #758076;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty {
  margin-top: 28rpx;
  padding: 44rpx 32rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  color: #758076;
  line-height: 1.55;
}

.empty-btn {
  width: 100%;
  margin-top: 30rpx;
}
