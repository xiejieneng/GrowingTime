.albums-page {
  padding-bottom: 80rpx;
}

.month-group {
  margin-bottom: 36rpx;
}

.month-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.month-title {
  font-size: 34rpx;
  font-weight: 700;
}

.month-count {
  margin-top: 6rpx;
  color: #758076;
  font-size: 24rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.album-card {
  position: relative;
  overflow: hidden;
}

.album-card image {
  display: block;
  width: 100%;
  height: 240rpx;
  background: #edf1ec;
}

.photo-delete {
  position: absolute;
  z-index: 2;
  top: 12rpx;
  right: 12rpx;
  width: 88rpx;
  min-height: 52rpx;
  height: 52rpx;
  padding: 0;
  color: #ffffff;
  background: rgba(35, 48, 41, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 8rpx;
  font-size: 22rpx;
}

.photo-delete[disabled] {
  color: rgba(255, 255, 255, 0.72);
  background: rgba(35, 48, 41, 0.5);
  border-color: rgba(255, 255, 255, 0.18);
}

.photo-delete-pressed {
  background: rgba(179, 65, 54, 0.92);
}

.album-meta {
  padding: 16rpx;
}

.album-date {
  font-weight: 700;
}

.album-place {
  margin-top: 6rpx;
  color: #758076;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty {
  margin-top: 28rpx;
  padding: 44rpx 32rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  color: #758076;
  line-height: 1.55;
}

.empty-btn {
  width: 100%;
  margin-top: 30rpx;
}
