.video-page {
  padding-bottom: 80rpx;
}

.form-panel {
  padding: 28rpx;
}

.field + .field {
  margin-top: 28rpx;
}

.field-title {
  font-weight: 700;
  margin-bottom: 12rpx;
}

input,
.picker-box {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #f6f8f4;
  border: 1rpx solid #e2e8df;
  border-radius: 8rpx;
}

.split-field {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.create-btn {
  width: 100%;
  margin-top: 32rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
}

.link {
  color: #2f6b55;
  font-size: 26rpx;
  font-weight: 700;
}

.select-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.select-card {
  position: relative;
  height: 212rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  background: #edf1ec;
}

.select-card image {
  width: 100%;
  height: 100%;
  display: block;
}

.select-card.selected {
  border-color: #2f6b55;
}

.checkmark {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
  border-radius: 50%;
  color: #ffffff;
  background: rgba(47, 107, 85, 0.92);
  font-weight: 700;
}

.task-list {
  margin-top: 18rpx;
}

.task {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.task-main {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-weight: 700;
}

.task-meta {
  margin-top: 8rpx;
  color: #758076;
  font-size: 24rpx;
  word-break: break-all;
}

.task-status {
  color: #2f6b55;
  font-weight: 700;
  font-size: 24rpx;
  text-align: right;
}

.task-status.failed {
  color: #b34136;
}

.task-side {
  flex: 0 0 150rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.task-play {
  width: 150rpx;
  min-height: 58rpx;
  height: 58rpx;
  margin-top: 14rpx;
  padding: 0;
  color: #ffffff;
  background: #2f6b55;
  border-radius: 8rpx;
  font-size: 23rpx;
}

.task-delete {
  width: 150rpx;
  min-height: 58rpx;
  height: 58rpx;
  margin-top: 12rpx;
  padding: 0;
  color: #b34136;
  background: #fff5f3;
  border: 1rpx solid #efd5d0;
  border-radius: 8rpx;
  font-size: 23rpx;
}

.task-delete[disabled] {
  color: #b98e88;
  background: #faf3f1;
  border-color: #eee0dd;
}

.player-mask {
  position: fixed;
  z-index: 100;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(22, 31, 26, 0.58);
}

.player-sheet {
  box-sizing: border-box;
  width: 100%;
  padding: 28rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 12rpx 12rpx 0 0;
}

.player-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.player-title {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
  font-size: 32rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-close {
  color: #2f6b55;
  font-size: 26rpx;
  font-weight: 700;
}

.online-player {
  width: 100%;
  height: 390rpx;
  background: #111111;
  border-radius: 8rpx;
  overflow: hidden;
}

.player-error {
  margin-top: 16rpx;
  color: #b34136;
  font-size: 24rpx;
}

.player-meta {
  margin-top: 18rpx;
  color: #758076;
  font-size: 24rpx;
}

.empty {
  margin-top: 18rpx;
  padding: 40rpx 32rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  color: #758076;
  line-height: 1.55;
}

.empty-btn {
  width: 100%;
  margin-top: 30rpx;
}
