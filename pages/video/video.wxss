.video-page {
  padding-bottom: 300rpx;
}

.form-panel {
  padding: 28rpx;
}

.field + .field {
  margin-top: 28rpx;
}

.field-title {
  font-weight: 700;
  margin-bottom: 12rpx;
}

input,
.picker-box {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #f6f8f4;
  border: 1rpx solid #e2e8df;
  border-radius: 8rpx;
}

.split-field {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.create-btn {
  width: 100%;
  margin-top: 32rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
}

.link {
  color: #2f6b55;
  font-size: 26rpx;
  font-weight: 700;
}

.record-actions {
  display: flex;
  align-items: center;
}

.record-actions .link + .link {
  margin-left: 24rpx;
}

.select-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.select-card {
  position: relative;
  height: 212rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  background: #edf1ec;
}

.select-card image {
  width: 100%;
  height: 100%;
  display: block;
}

.select-card.selected {
  border-color: #2f6b55;
}

.checkmark {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
  border-radius: 50%;
  color: #ffffff;
  background: rgba(47, 107, 85, 0.92);
  font-weight: 700;
}

.task-list {
  margin-top: 18rpx;
}

.task {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.task.selected {
  border-color: #2f6b55;
  background: #f7fbf8;
}

.record-check {
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #ffffff;
  border: 3rpx solid #cbd6ce;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 800;
}

.record-check.checked {
  background: #2f6b55;
  border-color: #2f6b55;
}

.task-main {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-weight: 700;
}

.task-meta {
  margin-top: 8rpx;
  color: #758076;
  font-size: 24rpx;
  word-break: break-all;
}

.task-status {
  color: #2f6b55;
  font-weight: 700;
  font-size: 24rpx;
  text-align: right;
}

.task-status.failed {
  color: #b34136;
}

.task-side {
  flex: 0 0 150rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.task-play {
  width: 150rpx;
  min-height: 58rpx;
  height: 58rpx;
  margin-top: 14rpx;
  padding: 0;
  color: #ffffff;
  background: #2f6b55;
  border-radius: 8rpx;
  font-size: 23rpx;
}

.batch-bar {
  position: fixed;
  z-index: 20;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(92rpx + env(safe-area-inset-bottom));
  height: 104rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8e1;
  border-radius: 12rpx;
  box-shadow: 0 12rpx 36rpx rgba(35, 48, 41, 0.16);
}

.batch-select {
  color: #2f6b55;
  font-weight: 700;
}

.batch-count {
  flex: 1;
  margin-left: 24rpx;
  color: #758076;
  font-size: 24rpx;
}

.batch-delete {
  width: 144rpx;
  min-height: 64rpx;
  height: 64rpx;
  padding: 0;
  color: #ffffff;
  background: #b34136;
  font-size: 25rpx;
}

.batch-delete[disabled] {
  color: #baaaa7;
  background: #f0e9e7;
}
.player-mask {
  position: fixed;
  z-index: 100;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(22, 31, 26, 0.58);
}

.player-sheet {
  box-sizing: border-box;
  width: 100%;
  padding: 28rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 12rpx 12rpx 0 0;
}

.player-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.player-title {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
  font-size: 32rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-close {
  color: #2f6b55;
  font-size: 26rpx;
  font-weight: 700;
}

.online-player {
  width: 100%;
  height: 390rpx;
  background: #111111;
  border-radius: 8rpx;
  overflow: hidden;
}

.preview-player {
  position: relative;
  width: 100%;
  height: 520rpx;
  background: #111111;
  border-radius: 8rpx;
  overflow: hidden;
}

.preview-image {
  position: absolute;
  left: -5%;
  top: -5%;
  width: 110%;
  height: 110%;
  transform-origin: center center;
  will-change: transform, opacity;
}

.motion-zoom-in {
  animation-name: previewZoomIn;
  animation-timing-function: ease-out;
  animation-fill-mode: both;
}

.motion-pan-left {
  animation-name: previewPanLeft;
  animation-timing-function: ease-in-out;
  animation-fill-mode: both;
}

.motion-pan-right {
  animation-name: previewPanRight;
  animation-timing-function: ease-in-out;
  animation-fill-mode: both;
}

.motion-pull-back {
  animation-name: previewPullBack;
  animation-timing-function: ease-out;
  animation-fill-mode: both;
}

@keyframes previewZoomIn {
  0% {
    opacity: 0;
    transform: scale(1);
  }
  14% {
    opacity: 1;
  }
  100% {
    opacity: 1;
    transform: scale(1.16);
  }
}

@keyframes previewPanLeft {
  0% {
    opacity: 0;
    transform: scale(1.13) translateX(4%);
  }
  14% {
    opacity: 1;
  }
  100% {
    opacity: 1;
    transform: scale(1.13) translateX(-4%);
  }
}

@keyframes previewPanRight {
  0% {
    opacity: 0;
    transform: scale(1.13) translateX(-4%);
  }
  14% {
    opacity: 1;
  }
  100% {
    opacity: 1;
    transform: scale(1.13) translateX(4%);
  }
}

@keyframes previewPullBack {
  0% {
    opacity: 0;
    transform: scale(1.18);
  }
  14% {
    opacity: 1;
  }
  100% {
    opacity: 1;
    transform: scale(1.02);
  }
}

.preview-shade {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(15, 21, 18, 0.08) 38%, rgba(15, 21, 18, 0.72) 100%);
}

.preview-caption {
  position: absolute;
  left: 28rpx;
  right: 100rpx;
  bottom: 40rpx;
  color: #ffffff;
}

.preview-theme {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.25;
}

.preview-style {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
}

.preview-counter {
  position: absolute;
  right: 24rpx;
  bottom: 44rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
  font-weight: 700;
}

.preview-progress {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.24);
}

.preview-progress-fill {
  height: 100%;
  background: #ffffff;
  transform-origin: left center;
}

.preview-progress-fill {
  animation-name: previewProgress;
  animation-timing-function: linear;
  animation-fill-mode: both;
}

@keyframes previewProgress {
  from {
    transform: scaleX(0);
  }
  to {
    transform: scaleX(1);
  }
}

.preview-badge {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 8rpx 14rpx;
  color: #2f6b55;
  background: #edf5ef;
  border-radius: 8rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.player-error {
  margin-top: 16rpx;
  color: #b34136;
  font-size: 24rpx;
}

.player-meta {
  margin-top: 18rpx;
  color: #758076;
  font-size: 24rpx;
}

.empty {
  margin-top: 18rpx;
  padding: 40rpx 32rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  color: #758076;
  line-height: 1.55;
}

.empty-btn {
  width: 100%;
  margin-top: 30rpx;
}
