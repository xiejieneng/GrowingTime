<view class="page video-page">
  <view class="title">AI 成长短视频</view>
  <view class="subtitle">选择一张宝宝照片，由 AI 生成具有真实动作、镜头运动和环境变化的短视频，不再使用照片轮播代替成品。</view>

  <view class="section panel form-panel">
    <view class="field">
      <view class="field-title">视频主题</view>
      <input value="{{theme}}" placeholder="例如：一岁生日、第一次旅行" bindinput="onThemeInput" />
    </view>

    <view class="field split-field">
      <view>
        <view class="field-title">视频风格</view>
        <picker range="{{styles}}" value="{{styleIndex}}" bindchange="onStyleChange">
          <view class="picker-box">{{styles[styleIndex]}}</view>
        </picker>
      </view>
      <view>
        <view class="field-title">时长</view>
        <picker range="{{durations}}" value="{{durationIndex}}" bindchange="onDurationChange">
          <view class="picker-box">{{durations[durationIndex]}}秒</view>
        </picker>
      </view>
    </view>

    <button class="primary-btn create-btn" hover-class="button-pressed" loading="{{creating}}" disabled="{{creating || !selectedCount}}" bindtap="createVideo">
      {{creating ? "提交中" : "生成短视频"}}
    </button>
  </view>

  <view class="section section-head">
    <view class="section-title">选择照片</view>
    <view class="muted">{{selectedCount ? "已选择" : "请选择 1 张"}}</view>
  </view>

  <view wx:if="{{photos.length}}" class="select-grid">
    <view wx:for="{{photos}}" wx:key="id" class="select-card {{item.selected ? 'selected' : ''}}" bindtap="togglePhoto" data-id="{{item.id}}">
      <image src="{{item.compressedPath || item.path}}" mode="aspectFill" fade-in="{{false}}"></image>
      <view class="checkmark">{{item.selected ? "✓" : ""}}</view>
    </view>
  </view>

  <view wx:else class="empty panel">
    <view class="empty-title">先整理几张照片</view>
    <view class="empty-text">AI 视频会使用“相册”里已经整理好的照片作为素材。</view>
    <button class="primary-btn empty-btn" hover-class="button-pressed" bindtap="goUpload">去整理</button>
  </view>

  <view wx:if="{{videos.length}}" class="section">
    <view class="section-head">
      <view class="section-title">生成记录</view>
      <view class="record-actions">
        <view wx:if="{{!managingVideos}}" class="link refresh-link" bindtap="refreshTasks">{{refreshing ? "刷新中" : "刷新状态"}}</view>
        <view class="link" bindtap="toggleVideoManage">{{managingVideos ? "取消" : "管理"}}</view>
      </view>
    </view>
    <view class="task-list">
      <view wx:for="{{videos}}" wx:key="id" class="task panel {{item.selected ? 'selected' : ''}}" data-id="{{item.id}}" bindtap="toggleVideoSelection">
        <view wx:if="{{managingVideos}}" class="record-check {{item.selected ? 'checked' : ''}}">{{item.selected ? "✓" : ""}}</view>
        <view class="task-main">
          <view class="task-title">{{item.theme}}</view>
          <view class="task-meta">{{item.style}} · {{item.duration}}秒 · {{item.photoCount}}张</view>
          <view class="task-meta">任务：{{item.taskId}}</view>
        </view>
        <view class="task-side">
          <view class="task-status {{item.failed ? 'failed' : ''}}">{{item.statusText}}</view>
          <button wx:if="{{item.playable && !managingVideos}}" class="task-play" hover-class="button-pressed" data-id="{{item.id}}" catchtap="playVideo">在线播放</button>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{managingVideos}}" class="batch-bar">
    <view class="batch-select" bindtap="selectAllVideos">{{selectedVideoIds.length === videos.length ? "取消全选" : "全选"}}</view>
    <view class="batch-count">已选 {{selectedVideoIds.length}} 条</view>
    <button class="batch-delete" disabled="{{!selectedVideoIds.length || deletingVideos}}" loading="{{deletingVideos}}" bindtap="deleteSelectedVideos">删除</button>
  </view>

  <view wx:if="{{activeVideo}}" class="player-mask">
    <view class="player-sheet">
      <view class="player-head">
        <view class="player-title">{{activeVideo.theme}}</view>
        <view class="player-close" bindtap="closePlayer">关闭</view>
      </view>
      <video
        wx:if="{{!activeVideo.previewOnly}}"
        id="growthVideo"
        class="online-player"
        src="{{activeVideo.src}}"
        poster="{{activeVideo.cover}}"
        controls
        autoplay
        object-fit="contain"
        show-center-play-btn
        show-fullscreen-btn
        enable-play-gesture
        binderror="onPlayerError"
      ></video>
      <view
        wx:else
        class="preview-player"
      >
        <image
          wx:if="{{activeVideo.previewCycle === 'a'}}"
          class="preview-image motion-{{activeVideo.previewMotion}}"
          style="animation-duration: {{activeVideo.previewAnimationDuration}}ms;"
          src="{{activeVideo.previewCurrent}}"
          mode="aspectFill"
          fade-in="{{false}}"
        ></image>
        <image
          wx:else
          class="preview-image motion-{{activeVideo.previewMotion}}"
          style="animation-duration: {{activeVideo.previewAnimationDuration}}ms;"
          src="{{activeVideo.previewCurrent}}"
          mode="aspectFill"
          fade-in="{{false}}"
        ></image>
        <view class="preview-shade"></view>
        <view class="preview-caption">
          <view class="preview-theme">{{activeVideo.theme}}</view>
          <view class="preview-style">{{activeVideo.style}}</view>
        </view>
        <view class="preview-counter">{{activeVideo.previewIndex + 1}} / {{activeVideo.previewPhotos.length}}</view>
        <view class="preview-progress">
          <view
            wx:if="{{activeVideo.previewCycle === 'a'}}"
            class="preview-progress-fill"
            style="animation-duration: {{activeVideo.previewInterval}}ms;"
          ></view>
          <view
            wx:else
            class="preview-progress-fill"
            style="animation-duration: {{activeVideo.previewInterval}}ms;"
          ></view>
        </view>
      </view>
      <view wx:if="{{activeVideo.previewOnly}}" class="preview-badge">成长片段预览</view>
      <view wx:if="{{playerError}}" class="player-error">{{playerError}}</view>
      <view class="player-meta">{{activeVideo.style}} · {{activeVideo.duration}}秒 · {{activeVideo.photoCount}}张照片</view>
    </view>
  </view>
</view>
