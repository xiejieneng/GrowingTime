.home-page {
  padding: 28rpx 36rpx 64rpx;
  padding-bottom: 48rpx;
}

.account-strip {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 0 4rpx 28rpx;
}

.account-avatar {
  flex: 0 0 76rpx;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #2f6b55;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 800;
}

.account-copy {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.account-name {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
}

.account-hint {
  margin-top: 6rpx;
  color: #758076;
  font-size: 24rpx;
  line-height: 1.3;
}

.account-action {
  flex: 0 0 auto;
  margin-left: 16rpx;
  color: #2f6b55;
  font-size: 26rpx;
  font-weight: 800;
  white-space: nowrap;
}

.hero {
  box-sizing: border-box;
  min-height: 440rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 48rpx 40rpx;
  border-radius: 12rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #245f4a 0%, #70a56c 58%, #eeb36b 100%);
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: "";
  position: absolute;
  width: 260rpx;
  height: 260rpx;
  right: -72rpx;
  bottom: -116rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  box-shadow: 0 0 0 34rpx rgba(255, 255, 255, 0.05);
}

.hero-copy,
.hero-actions {
  position: relative;
  z-index: 1;
}

.hero .pill {
  min-height: 48rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 24rpx;
  color: #ffffff;
  font-size: 56rpx;
  line-height: 1.16;
  font-weight: 800;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 28rpx;
  line-height: 1.55;
}

.hero-actions {
  display: flex;
  margin-top: 32rpx;
}

.action-btn {
  flex: 1;
  width: auto;
  box-sizing: border-box;
  height: 88rpx;
  padding: 0;
  margin: 0;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.action-btn + .action-btn {
  margin-left: 20rpx;
}

.action-btn::after {
  border: 0;
}

.stats {
  display: flex;
  margin-top: 40rpx;
}

.stat {
  flex: 1;
  box-sizing: border-box;
  min-width: 0;
  padding: 30rpx 10rpx;
  text-align: center;
}

.stat + .stat {
  margin-left: 16rpx;
}

.stat-value {
  font-size: 48rpx;
  line-height: 1.15;
  font-weight: 800;
  color: #2f6b55;
}

.stat-label {
  margin-top: 8rpx;
  color: #758076;
  font-size: 24rpx;
  line-height: 1.3;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.link {
  color: #2f6b55;
  font-size: 26rpx;
  font-weight: 700;
}

.storage-card {
  margin-top: 40rpx;
  padding: 32rpx;
}

.storage-head {
  margin-top: 0;
}

.storage-title-wrap {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.storage-desc {
  margin-top: 8rpx;
  color: #758076;
  font-size: 24rpx;
  line-height: 1.4;
}

.storage-badge {
  flex: 0 0 auto;
  min-width: 116rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #2f6b55;
  background: #edf5ef;
  border-radius: 8rpx;
  font-weight: 700;
}

.storage-bars {
  margin-top: 24rpx;
}

.bar-row {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.bar-label,
.bar-size {
  flex: 0 0 116rpx;
  color: #758076;
  font-size: 24rpx;
}

.bar-size {
  text-align: right;
}

.bar-track {
  flex: 1;
  height: 16rpx;
  margin: 0 16rpx;
  overflow: hidden;
  background: #edf1ec;
  border-radius: 999rpx;
}

.bar-fill {
  height: 100%;
  min-width: 8rpx;
  border-radius: 999rpx;
}

.bar-fill.display {
  background: #2f6b55;
}

.bar-fill.original {
  background: #f1b66b;
}

.saving-text {
  margin-top: 24rpx;
  color: #8a5a12;
  background: #fff8ec;
  border: 1rpx solid #f4dfbd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 24rpx;
  line-height: 1.4;
}

.recent-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 20rpx;
}

.photo-card {
  box-sizing: border-box;
  width: calc(50% - 10rpx);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.photo-card image {
  width: 100%;
  height: 264rpx;
  display: block;
}

.photo-meta {
  padding: 16rpx;
}

.photo-date {
  font-weight: 600;
}

.photo-place {
  margin-top: 6rpx;
  color: #758076;
  font-size: 24rpx;
}

.empty {
  margin-top: 20rpx;
  padding: 48rpx 36rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  color: #758076;
  line-height: 1.55;
}
