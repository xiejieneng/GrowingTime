<view class="page upload-page">
  <view class="title">图片高清整理</view>
  <view class="subtitle">优先读取照片内的拍摄日期和 GPS；手机未提供原始信息时，可在整理结果中手动补录日期。</view>

  <view class="section panel control-panel">
    <view class="storage-mode">
      <view>
        <view class="field-title">存储方案</view>
        <view class="field-desc">{{storageModeText}}</view>
      </view>
      <switch checked="{{uploadOriginal}}" color="#2F6B55" bindchange="onOriginalSwitch" />
    </view>

    <view class="saving-note">
      <view class="note-title">{{loggedIn ? "省钱模式" : "游客本地存储"}}</view>
      <view class="note-text">{{loggedIn ? "默认只上传展示图和照片索引；开启高清备份后，仅在 Wi‑Fi 下额外上传原图。" : "未注册登录时不会上传照片。清理小程序数据或更换手机可能导致记录丢失。"}}</view>
    </view>

    <view class="field-row">
      <view>
        <view class="field-title">压缩质量</view>
        <view class="field-desc">数值越高越接近原图，体积越大</view>
      </view>
      <view class="quality-value">{{quality}}%</view>
    </view>
    <slider min="70" max="98" step="1" value="{{quality}}" activeColor="#2F6B55" block-size="20" bindchange="onQualityChange" />

    <view class="field-row max-row">
      <view>
        <view class="field-title">最长边限制</view>
        <view class="field-desc">原生快速压缩，默认 4096px 保持高清</view>
      </view>
      <picker range="{{maxSideOptions}}" value="{{maxSideIndex}}" bindchange="onMaxSideChange">
        <view class="picker-value">{{maxSideOptions[maxSideIndex]}}px</view>
      </picker>
    </view>

    <button class="primary-btn choose-btn" hover-class="button-pressed" loading="{{processing}}" disabled="{{processing}}" bindtap="chooseImages">
      {{processing ? "处理中" : "选择照片"}}
    </button>
    <view class="speed-note">{{syncing ? "照片已可使用，正在后台同步云端" : "最多 3 张并行处理，本地完成后立即可用"}}</view>
  </view>

  <view wx:if="{{queue.length}}" class="section section-head">
    <view class="section-title">本次处理</view>
    <view class="muted">{{queue.length}} 张</view>
  </view>

  <view class="queue">
    <view wx:for="{{queue}}" wx:key="id" class="queue-item panel">
      <image src="{{item.compressedPath || item.path}}" mode="aspectFill" fade-in="{{false}}"></image>
      <view class="queue-body">
        <view class="queue-title">{{item.statusText}}</view>
        <view class="queue-meta queue-date">
          <text>{{item.displayDate}} · {{item.placeText}}</text>
          <picker wx:if="{{item.dateUnknown}}" mode="date" data-id="{{item.id}}" bindchange="onPhotoDateChange">
            <view class="date-fix">补录日期</view>
          </picker>
        </view>
        <view class="queue-meta">{{item.sizeText}}</view>
        <view wx:if="{{item.cloudText}}" class="queue-cloud">{{item.cloudText}}</view>
      </view>
    </view>
  </view>
</view>
