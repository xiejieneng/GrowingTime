.upload-page {
  padding-bottom: 280rpx;
}

.control-panel {
  padding: 28rpx;
}

.storage-mode {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.saving-note {
  padding: 20rpx;
  margin-bottom: 28rpx;
  background: #fff8ec;
  border: 1rpx solid #f4dfbd;
  border-radius: 8rpx;
}

.note-title {
  color: #8a5a12;
  font-weight: 700;
}

.note-text {
  margin-top: 6rpx;
  color: #7d6b4d;
  font-size: 24rpx;
  line-height: 1.45;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.field-title {
  font-weight: 700;
}

.field-desc {
  margin-top: 6rpx;
  color: #758076;
  font-size: 24rpx;
}

.quality-value,
.picker-value {
  min-width: 132rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  color: #2f6b55;
  background: #edf5ef;
  border-radius: 8rpx;
  font-weight: 700;
}

.max-row {
  margin-top: 28rpx;
}

.choose-btn {
  width: 100%;
  margin-top: 32rpx;
}

.speed-note {
  margin-top: 14rpx;
  color: #758076;
  font-size: 23rpx;
  text-align: center;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
}

.queue-head-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.manage-link {
  color: #2f6b55;
  font-size: 26rpx;
  font-weight: 700;
}

.queue {
  margin-top: 18rpx;
}

.queue-item {
  position: relative;
  display: grid;
  grid-template-columns: 180rpx 1fr;
  gap: 20rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
}

.queue-item.selected {
  border-color: #2f6b55;
  background: #f7fbf8;
}

.record-check {
  position: absolute;
  z-index: 2;
  top: 12rpx;
  left: 12rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: rgba(35, 48, 41, 0.45);
  border: 3rpx solid #ffffff;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 800;
}

.record-check.checked {
  background: #2f6b55;
}

.queue-item image {
  width: 180rpx;
  height: 180rpx;
  display: block;
}

.queue-body {
  min-width: 0;
  padding: 20rpx 20rpx 20rpx 0;
}

.queue-title {
  font-weight: 700;
}

.queue-meta {
  margin-top: 10rpx;
  color: #758076;
  font-size: 24rpx;
  line-height: 1.4;
}

.queue-date {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.date-fix {
  padding: 5rpx 12rpx;
  color: #2f6b55;
  background: #edf5ef;
  border: 1rpx solid #cfe2d5;
  border-radius: 6rpx;
  font-weight: 700;
}

.queue-cloud {
  margin-top: 10rpx;
  color: #2f6b55;
  font-size: 24rpx;
  line-height: 1.4;
}

.batch-bar {
  position: fixed;
  z-index: 20;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(92rpx + env(safe-area-inset-bottom));
  height: 104rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8e1;
  border-radius: 12rpx;
  box-shadow: 0 12rpx 36rpx rgba(35, 48, 41, 0.16);
}

.batch-select {
  color: #2f6b55;
  font-weight: 700;
}

.batch-count {
  flex: 1;
  margin-left: 24rpx;
  color: #758076;
  font-size: 24rpx;
}

.batch-delete {
  width: 176rpx;
  min-height: 64rpx;
  height: 64rpx;
  padding: 0;
  color: #ffffff;
  background: #b34136;
  font-size: 24rpx;
}

.batch-delete[disabled] {
  color: #baaaa7;
  background: #f0e9e7;
}
